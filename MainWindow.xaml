<Window x:Class="PrintSpooler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generic TSPL Print Spooler" Height="500" Width="800" Background="#f3f4f6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Settings -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="15">
                <TextBlock Text="Spooler Setup" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <TextBlock Text="API Endpoint URL (GET):" FontWeight="Bold"/>
                <TextBlock Text="e.g. http://localhost:8000/api/queenprint/pending" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox x:Name="ApiUrlBox" Text="http://localhost:8000/api/queenprint/pending" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Printer Name:" FontWeight="Bold"/>
                <ComboBox x:Name="PrinterComboBox" Margin="0,5,0,25" Padding="5"/>

                <Button x:Name="PollButton" Content="Start Background Polling" Background="#022c22" Foreground="#d4af37" Padding="15" FontWeight="Bold" Click="PollButton_Click" Margin="0,0,0,20"/>

                <TextBlock x:Name="StatusLog" Text="Status: Idle" Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Log Area -->
        <Border Grid.Column="1" Background="White" Margin="15" CornerRadius="8" BorderBrush="#e5e7eb" BorderThickness="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Spooler Activity Log" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#f8fafc" BorderBrush="#cbd5e1" Padding="10" TextWrapping="Wrap" FontFamily="Consolas" />
            </Grid>
        </Border>
    </Grid>
</Window>
