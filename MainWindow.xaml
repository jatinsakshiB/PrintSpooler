<Window x:Class="RudrakshPrintSpooler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rudraksh 925 Print Spooler" Height="700" Width="1000" Background="#f3f4f6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Settings -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="15">
                <TextBlock Text="Print Spooler Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <TextBlock Text="API URL:" FontWeight="Bold"/>
                <TextBox x:Name="ApiUrlBox" Text="http://localhost:8000/api" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Printer Name:" FontWeight="Bold"/>
                <ComboBox x:Name="PrinterComboBox" Margin="0,5,0,15" Padding="5"/>

                <Button x:Name="PollButton" Content="Start Background Polling" Background="#022c22" Foreground="#d4af37" Padding="10" FontWeight="Bold" Click="PollButton_Click" Margin="0,0,0,20"/>

                <TextBlock Text="Layout Settings (TSPL Dots)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="QR X Offset:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="QrXBox" Text="20" Grid.Row="0" Grid.Column="1" Margin="5" TextChanged="Setting_TextChanged"/>
                    <TextBlock Text="QR Y Offset:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="QrYBox" Text="10" Grid.Row="1" Grid.Column="1" Margin="5" TextChanged="Setting_TextChanged"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Text X Offset:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TextXBox" Text="360" Grid.Row="0" Grid.Column="1" Margin="5" TextChanged="Setting_TextChanged"/>
                    <TextBlock Text="Text Y Offset:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TextYBox" Text="10" Grid.Row="1" Grid.Column="1" Margin="5" TextChanged="Setting_TextChanged"/>
                </Grid>

                <TextBlock Text="Show Elements" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <CheckBox x:Name="ShowHuidCheck" Content="Show HUID" IsChecked="True" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                <CheckBox x:Name="ShowNameCheck" Content="Show Item Name" IsChecked="True" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                <CheckBox x:Name="ShowWeightCheck" Content="Show Weight/Metal" IsChecked="True" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                <CheckBox x:Name="ShowPriceCheck" Content="Show Price" IsChecked="True" Margin="0,0,0,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>

                <TextBlock x:Name="StatusLog" Text="Status: Idle" Foreground="Gray" Margin="0,30,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Preview Area -->
        <Border Grid.Column="1" Background="White" Margin="15" CornerRadius="8" BorderBrush="#e5e7eb" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Live Visual Preview" FontSize="18" FontWeight="Bold" Margin="15"/>
                
                <Border Grid.Row="1" Background="#f8fafc" Margin="15" BorderBrush="#cbd5e1" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="800" Height="400">
                    <!-- The canvas origin is top-left, matching TSPL closely -->
                    <Canvas x:Name="PreviewCanvas" ClipToBounds="True">
                        <Image x:Name="PreviewImage" Width="100" Height="100"/>
                    </Canvas>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
